{
  "permissions": {
    "allow": [
      "Bash(npx uuid v7)",
      "Bash(uuidgen:*)",
      "Bash(git rev-parse:*)",
      "Bash(mkdir:*)",
      "Bash(bun --version:*)",
      "Bash(substrate:*)",
      "Bash(bun run test:e2e*)",
      "Bash(make bun-test-e2e*)",
      "Bash(playwright test*)",
      "Bash(npx playwright*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm*~/.claude/tasks/*)",
      "Bash(rm*/.claude/tasks/*)",
      "Bash(*rm*tasks/*.json*)",
      "Read(~/.zshrc)",
      "Read(~/.zshenv)",
      "Read(~/.zprofile)",
      "Read(~/.bashrc)",
      "Read(~/.bash_profile)",
      "Read(~/.bash_history)",
      "Read(~/.zsh_history)",
      "Read(~/.ssh/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.netrc)",
      "Read(~/.aws/*)",
      "Read(~/.config/gh/hosts.yml)",
      "Bash(*cat*~/.zshrc*)",
      "Bash(*cat*~/.bashrc*)",
      "Bash(*cat*~/.ssh/*)",
      "Bash(*cat*~/.netrc*)",
      "Bash(*cat*~/.aws/*)",
      "Read(~/Library/Keychains/*)",
      "Bash(*cat*~/Library/Keychains/*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/notification.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": []
      },
      {
        "matcher": "TaskCreate|TaskUpdate|TaskList|TaskGet",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/task_sync.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/posttooluse_plan.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/roasbeef/.claude/hooks/precompact/save_important_context.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/pre_compact.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": []
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/pretooluse_plan.sh",
            "timeout": 600
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/roasbeef/.claude/hooks/sessionstart/load_project_context.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'POST-COMPACTION: You MUST immediately run /session-resume to restore session context before doing anything else.'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/session_start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/stop.sh",
            "timeout": 600
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/subagent_stop.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/roasbeef/.claude/hooks/ultrathink_hook.py"
          },
          {
            "type": "command",
            "command": "/Users/roasbeef/.claude/hooks/userpromptsubmit/context_enhancer.py"
          },
          {
            "type": "command",
            "command": "/Users/roasbeef/.claude/hooks/userpromptsubmit/session_context.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/substrate/user_prompt.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=\"$(echo \"$input\" | jq -r '.workspace.current_dir')\"; model=\"$(echo \"$input\" | jq -r '.model.display_name')\"; if [ -d \"$cwd/.git\" ]; then cd \"$cwd\" 2>/dev/null && branch=$(git branch --show-current 2>/dev/null); if [ -n \"$branch\" ]; then git_info=\" [$branch]\"; else git_info=\" [detached]\"; fi; changes=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' '); if [ \"$changes\" -gt 0 ]; then git_info=\"$git_info *\"; fi; else git_info=\"\"; fi; printf \"⛰ %s | %s%s | %s\" \"$(whoami)\" \"$(basename \"$cwd\")\" \"$git_info\" \"$model\""
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "ralph-wiggum@claude-plugins-official": false,
    "gh-cli@trailofbits": true,
    "git-cleanup@trailofbits": true,
    "workflow-skill-design@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "spec-to-code-compliance@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "differential-review@trailofbits": true,
    "second-opinion@trailofbits": true,
    "property-based-testing@trailofbits": true,
    "insecure-defaults@trailofbits": true,
    "audit-context-building@trailofbits": true,
    "ask-questions-if-underspecified@trailofbits": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.golang.org",
        "proxy.golang.org",
        "sum.golang.org",
        "pkg.go.dev",
        "*.npmjs.org",
        "registry.npmjs.org",
        "*.pypi.org",
        "pypi.org"
      ],
      "allowUnixSockets": [
        "/var/run/docker.sock",
        "/Users/roasbeef/.gnupg/S.gpg-agent.ssh"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {},
    "excludedCommands": [
      "docker",
      "git",
      "gh",
      "npx playwright",
      "bun run test:e2e"
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1753983872081
  }
}
